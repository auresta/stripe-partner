# Copy this file to `.env` and paste in the test key the Owner sent you.
# Never commit `.env` to git. Never share these values.

# Your sandbox test key (rk_test_…) — one scoped key for the whole build
# (catalogue + payments). All scripts read STRIPE_KEY_SANDBOX.
STRIPE_KEY_SANDBOX=rk_test_paste_here

# Live key is Owner-only — you will not receive one during the build.
# STRIPE_KEY_LIVE=rk_live_paste_here

# Identifier stamped on every object you create, via metadata.created_by.
# Use lowercase initials prefixed with "partner-", e.g. partner-jd.
PARTNER_TAG=partner-CHANGE-ME
