# Copy this file to `.env` and paste in the keys the Owner provided.
# Never commit `.env` to git. Never share these values.

STRIPE_KEY_SANDBOX=rk_sandbox_paste_here
STRIPE_KEY_LIVE=rk_live_paste_here

# Identifier stamped on every object you create, via metadata.created_by.
# Use lowercase initials prefixed with "partner-", e.g. partner-jd.
PARTNER_TAG=partner-CHANGE-ME
